---
/**
 * RevealList Component - Container for staggered reveal animations
 * 
 * @param stagger - Delay between each child animation in ms
 * @param as - HTML tag to render (default: 'div')
 * @param class - Additional CSS classes
 * 
 * @example
 * <RevealList stagger={100}>
 *   <Reveal direction="left">Item 1</Reveal>
 *   <Reveal direction="right">Item 2</Reveal>
 * </RevealList>
 */

interface Props {
  stagger?: number;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const {
  stagger = 100,
  as: Tag = "div",
  class: className = "",
} = Astro.props;
---

<Tag data-stagger={stagger} class={className}>
  <slot />
</Tag>

